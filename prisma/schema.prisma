generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id                 Int              @id @default(autoincrement())
  cart_id            Int
  product_variant_id Int
  quantity           Int
  carts              carts            @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants @relation(fields: [product_variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cart_id, product_variant_id])
}

model carts {
  id         Int          @id @default(autoincrement())
  user_id    Int?         @unique
  created_at DateTime     @default(now()) @db.Timestamp(6)
  updated_at DateTime     @default(now()) @db.Timestamp(6)
  cart_items cart_items[]
  users      users?       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model categories {
  id               Int          @id @default(autoincrement())
  name             String       @db.VarChar(150)
  parent_id        Int?
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
}

model deliveries {
  id              Int             @id @default(autoincrement())
  order_id        Int
  provider        String          @db.VarChar(100)
  tracking_number String?         @db.VarChar(255)
  status          delivery_status @default(PENDING)
  shipped_at      DateTime?       @db.Timestamp(6)
  delivered_at    DateTime?       @db.Timestamp(6)
  orders          orders          @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory {
  id                 Int              @id @default(autoincrement())
  product_variant_id Int
  quantity           Int
  reserved_quantity  Int              @default(0)
  product_variants   product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_variant_id], map: "idx_inventory_variant")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id                 Int               @id @default(autoincrement())
  order_id           Int
  product_variant_id Int?
  title_snapshot     String            @db.VarChar(255)
  price_snapshot     Decimal           @db.Decimal(12, 2)
  quantity           Int
  orders             orders            @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id             Int             @id @default(autoincrement())
  user_id        Int
  address_id     Int?
  status         order_status    @default(PENDING_CONFIRMATION)
  total_amount   Decimal         @db.Decimal(12, 2)
  currency       String          @default("ГРН") @db.VarChar(10)
  created_at     DateTime        @default(now()) @db.Timestamp(6)
  updated_at     DateTime        @default(now()) @db.Timestamp(6)
  deliveries     deliveries[]
  order_items    order_items[]
  user_addresses user_addresses? @relation(fields: [address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       payments[]

  @@index([user_id], map: "idx_orders_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id             Int            @id @default(autoincrement())
  order_id       Int
  provider       String         @db.VarChar(100)
  status         payment_status @default(PENDING)
  amount         Decimal        @db.Decimal(12, 2)
  currency       String         @db.VarChar(10)
  transaction_id String?        @db.VarChar(255)
  created_at     DateTime       @default(now()) @db.Timestamp(6)
  orders         orders         @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_payments_order")
}

model product_images {
  id               Int              @id @default(autoincrement())
  variant_id       Int
  image_url        String
  position         Int?             @default(0)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product_variants {
  id             Int              @id @default(autoincrement())
  product_id     Int
  size           String?          @db.VarChar(100)
  color          String?          @db.VarChar(100)
  sku            String           @unique @db.VarChar(100)
  price          Decimal?         @db.Decimal(12, 2)
  quantity       Int?             @default(0)
  material       String?          @db.VarChar(150)
  weight         Decimal?         @db.Decimal(10, 2)
  cart_items     cart_items[]
  inventory      inventory[]
  order_items    order_items[]
  product_images product_images[]
  products       products         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id               Int                @id @default(autoincrement())
  title            String             @db.VarChar(255)
  description      String?
  article          String             @unique @db.VarChar(100)
  is_active        Boolean            @default(true)
  category_id      Int?
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @default(now()) @db.Timestamp(6)
  product_variants product_variants[]
  categories       categories?        @relation(fields: [category_id], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_products_category")
}

model user_addresses {
  id          Int      @id @default(autoincrement())
  user_id     Int
  region      String   @db.VarChar(100)
  city        String   @db.VarChar(100)
  street      String   @db.VarChar(150)
  house       String   @db.VarChar(50)
  apartment   String?  @db.VarChar(50)
  postal_code String?  @db.VarChar(20)
  is_default  Boolean? @default(false)
  orders      orders[]
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id             Int              @id @default(autoincrement())
  first_name     String           @db.VarChar(100)
  last_name      String           @db.VarChar(100)
  middle_name    String?          @db.VarChar(100)
  phone          String?          @db.VarChar(20)
  email          String           @unique @db.VarChar(255)
  password_hash  String
  role           user_role        @default(user)
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @default(now()) @db.Timestamp(6)
  carts          carts?
  orders         orders[]
  user_addresses user_addresses[]
}

model articles {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  alt         String   @db.VarChar(150)
  description String?
  image_url   String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
}

enum delivery_status {
  PENDING    @map("очікує")
  SENT       @map("відправлено")
  IN_TRANSIT @map("в дорозі")
  DELIVERED  @map("доставлено")
  FAILED     @map("не вдалося")
}

enum order_status {
  PENDING_CONFIRMATION @map("очікує підтвердження")
  CONFIRMED            @map("підтверджено")
  PENDING_PAYMENT      @map("очікує платіж")
  PAID                 @map("оплачено")
  PAYMENT_FAILED       @map("платіж не вдалося")
  PENDING_SHIPMENT     @map("очікує відправлення")
  SHIPPED              @map("відправлено")
  DELIVERED            @map("доставлено")
  CANCELED             @map("скасовано")
}

enum payment_status {
  PENDING  @map("очікує")
  SUCCESS  @map("успішно")
  FAILED   @map("не вдалося")
  CANCELED @map("скасовано")
}

enum user_role {
  user
  admin
}
