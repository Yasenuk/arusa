{
  "name": "@org/api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "api-e2e",
    "implicitDependencies": [
      "api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/playwright:playwright",
        "outputs": [
          "{projectRoot}/test-output/playwright"
        ],
        "options": {
          "config": "apps/api-e2e/playwright.config.ts"
        },
        "dependsOn": [
          "api:build"
        ]
      }
    }
  }
}
